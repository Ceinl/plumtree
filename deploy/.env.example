# Copy to .env next to docker-compose.yml and fill in real values.
# Generate tokens with: openssl rand -hex 32

# Public origin of the dashboard/API (behind your TLS proxy).
PLUMTREE_PUBLIC_ORIGIN=https://plumtree.example.com

# Deploy token baked into released pt binaries (recoverable from them —
# scope it to deploy only and rotate if leaked).
PLUMTREE_DEV_TOKEN=

# Shared token between the SSH gateway and the control plane's gateway API.
PLUMTREE_GATEWAY_TOKEN=

# Shared token between the SSH gateway and the networkless runner broker.
PLUMTREE_RUNNER_TOKEN=

# Shared token between the control plane and the build worker.
PLUMTREE_BUILD_TOKEN=

# Base64-encoded 32-byte KEK for control-plane snapshot envelope encryption.
# Generate once with: openssl rand -base64 32 > ./control-plane-state.kek
# Keep this file out of git and out of Docker volumes; production should point
# at a file materialized by your managed secret store/agent.
PLUMTREE_STATE_ENCRYPTION_KEY_FILE=./control-plane-state.kek

# Allow running unclaimed deploys at ssh preview-<deployID>@host.
PLUMTREE_ANONYMOUS_PREVIEW=false

# Optional capacity overrides. The Compose defaults are deliberately modest.
# Setting a critical limit to unlimited makes production startup fail unless
# PLUMTREE_ACKNOWLEDGE_UNLIMITED_LIMITS=true is also set on that service.
PLUMTREE_MAX_APPS_PER_OWNER=5
PLUMTREE_MAX_SESSIONS_PER_APP_DAY=50
PLUMTREE_MAX_DEPLOYS_PER_HOUR=100
PLUMTREE_MAX_SESSIONS=64
PLUMTREE_MAX_CONNECTIONS=1024
PLUMTREE_MAX_CONNECTIONS_PER_IP=32
PLUMTREE_MAX_CONCURRENT_BUILDS=2
PLUMTREE_MAX_QUEUED_BUILDS=8
PLUMTREE_WORKER_MAX_CONCURRENT_BUILDS=1
PLUMTREE_WORKER_MAX_QUEUED_BUILDS=8
PLUMTREE_ACKNOWLEDGE_UNLIMITED_LIMITS=false
